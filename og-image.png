<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0B1221"/>
      <stop offset="1" stop-color="#111A31"/>
    </linearGradient>
    <filter id="shadow" x="-30%" y="-30%" width="160%" height="160%">
      <feDropShadow dx="0" dy="6" stdDeviation="12" flood-color="#000" flood-opacity="0.35"/>
    </filter>
  </defs>
  <rect x="0" y="0" width="1200" height="630" fill="url(#g1)"/>

  <!-- Decorative circuits/lines -->
  <g opacity="0.12" stroke="#93A0B6" stroke-width="2" fill="none">
    <path d="M80 520h220m20 0h60m20 0h240m-560 -40h160m20 0h220m20 0h80"/>
    <path d="M100 120h300m20 0h150m20 0h320"/>
    <circle cx="460" cy="120" r="6" fill="#93A0B6"/>
    <circle cx="780" cy="520" r="6" fill="#93A0B6"/>
  </g>

  <!-- OpenCV tri-color rings -->
  <g filter="url(#shadow)">
    <circle cx="940" cy="210" r="86" fill="none" stroke="#E53935" stroke-width="34"/>
    <circle cx="1080" cy="210" r="86" fill="none" stroke="#1E88E5" stroke-width="34"/>
    <circle cx="1010" cy="360" r="86" fill="none" stroke="#43A047" stroke-width="34"/>
  </g>

  <!-- Title and subtitle -->
  <g font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" fill="#FFFFFF">
    <text x="80" y="220" font-size="72" font-weight="700">OpenCV for Windows</text>
    <text x="80" y="280" font-size="32" fill="#D7DEEA">Download & Install (Windows 11/10)</text>
  </g>

  <!-- Feature bullets -->
  <g font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="22" fill="#C9D2E4">
    <text x="82" y="340">• Official 4.12.0 Windows installer</text>
    <text x="82" y="376">• Python & C++ setup guides</text>
    <text x="82" y="412">• CUDA/GPU tips and troubleshooting</text>
  </g>

  <!-- Button-like badge -->
  <g transform="translate(80,460)">
    <rect x="0" y="0" rx="18" ry="18" width="420" height="66" fill="#1E88E5"/>
    <text x="28" y="42" font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="26" font-weight="700" fill="#fff">Download OpenCV 4.12.0 for Windows</text>
  </g>

  <!-- Corner label -->
  <g font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="16" fill="#93A0B6" opacity="0.9">
    <text x="80" y="88">opencv-windows.github.io</text>
  </g>
</svg>
